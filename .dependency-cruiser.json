{
  "forbidden": [
    {
      "name": "no-circular",
      "severity": "warn",
      "from": {},
      "to": {
        "circular": true
      }
    }
  ],
  "options": {
    "doNotFollow": {
      "path": ["node_modules", ".nuxt"],
      "dependencyTypes": ["npm", "core", "type-only"]
    },
    "exclude": {
      "path": ["node_modules", ".nuxt", "dist", ".output"]
    },
    "tsPreCompilationDeps": false,
    "reporterOptions": {
      "text": {
        "highlightFocused": true
      }
    }
  }
}
