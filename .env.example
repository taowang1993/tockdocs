# Local dev port used by TockDocs.
NUXT_PORT=4987

# Base URL for root deployments. Keep this as / for standard Vercel runtime deploys.
NUXT_APP_BASE_URL=/

# Canonical site URL used by TockDocs for site metadata and llms links.
# Use your public deployment URL on Vercel (for example: https://tockdocs-pi-nine.vercel.app).
# Must not include a trailing slash; the config trims it, and Nuxt LLMs concatenates /llms-full.txt directly from this value.
# For local development, 127.0.0.1 avoids Nuxt Site Config warnings about localhost URLs.
NUXT_SITE_URL=http://127.0.0.1:4987

# Server-only AI provider configuration for the docs assistant.
# Supported values: vercel, openrouter, deepseek, nvidia, huggingface, groq, github, gemini, cloudflare
AI_PROVIDER=vercel

# Optional generic model override for the selected provider.
# Example for Vercel AI Gateway: AI_MODEL=google/gemini-3-flash
AI_MODEL=

# Vercel AI Gateway
# On Vercel you can also rely on the auto-injected VERCEL_OIDC_TOKEN instead of an API key.
# Use AI_GATEWAY_API_KEY for manual keys; Vercel reserves the VERCEL_* prefix.
AI_GATEWAY_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.5:free

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Nvidia
NVIDIA_API_KEY=
NVIDIA_MODEL=minimaxai/minimax-m2.7

# Hugging Face Router
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=deepseek-ai/DeepSeek-V4-Pro:together

# Groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# GitHub Models
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-5

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/google/gemma-4-26b-a4b-it

# Nuxt Studio authentication (GitHub auth for /admin)
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=
# Optional: restrict Studio access to specific GitHub emails
STUDIO_GITHUB_MODERATORS=

# Optional: explicitly expose the assistant UI in production.
# The UI is always enabled in local dev and also turns on automatically when matching provider credentials are present.
NUXT_PUBLIC_ASSISTANT_ENABLED=false

# Filesystem backend for the assistant's documentation retrieval.
#   mcp   — current TockDocs MCP tools (search-pages, list-pages, get-page)
#   index — injects a build-time INDEX.md into the prompt and exposes only get-page
#   gitfs — GitFS + just-bash: mounts docs at /repo and exposes a bash tool
ASSISTANT_FS_BACKEND=mcp

# GitFS source repo (only used when ASSISTANT_FS_BACKEND=gitfs).
# The AI only accesses docs/content — site code is not mounted.
GITFS_GITHUB_OWNER=taowang1993
GITFS_GITHUB_REPO=tockdocs
GITFS_REF=main
